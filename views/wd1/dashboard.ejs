<!doctype html>
<html lang="id">
  <head>
    <%- include('../partials/head', { title: pageTitle }) %>
  </head>
  <body class="page-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
      <%- include('../partials/topbar') %>

      <main class="app-content">
        <div class="content-narrow">

          <section class="stat-grid stat-grid--3">
            <div class="stat-card">
              <div class="stat-card-row">
                <div>
                  <div class="stat-card-label">Menunggu Keputusan Akhir</div>
                  <div class="stat-card-value"><%= requests.filter(r => r.status === 'Pending').length %></div>
                </div>
                <div class="stat-card-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
              </div>
            </div>

            <div class="stat-card">
              <div class="stat-card-row">
                <div>
                  <div class="stat-card-label">Disetujui Tahun Ini</div>
                  <div class="stat-card-value"><%= requests.filter(r => r.status === 'Approved').length %></div>
                </div>
                <div class="stat-card-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                </div>
              </div>
            </div>

            <div class="stat-card">
              <div class="stat-card-row">
                <div>
                  <div class="stat-card-label">Ditolak Tahun Ini</div>
                  <div class="stat-card-value"><%= requests.filter(r => r.status === 'Rejected').length %></div>
                </div>
                <div class="stat-card-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                </div>
              </div>
            </div>
          </section>

          <div class="card">
            <header style="display:flex; align-items:center; justify-content:space-between;">
              <div>
                <h2>Menunggu Keputusan Akhir</h2>
                <p>Telah disetujui Ketua Program Studi. Keputusan Anda bersifat final dan akan diterbitkan sebagai SK resmi.</p>
              </div>
              <a href="/wd1/submissions" class="btn-sm-outline">Lihat Semua</a>
            </header>
            <section>
              <div class="table-wrap">
                <table class="table">
                  <thead>
                    <tr>
                      <th>NIM</th>
                      <th>Nama Mahasiswa</th>
                      <th>Tanggal Masuk</th>
                      <th>Status Berkas</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (requests.length === 0) { %>
                      <tr>
                        <td colspan="6" class="text-center text-muted-foreground" style="padding: 2rem 0;">
                          Belum ada pengajuan yang menunggu keputusan akhir Anda.
                        </td>
                      </tr>
                    <% } else { %>
                      <% requests.forEach(req => { %>
                        <tr>
                          <td><strong><%= req.regno %></strong></td>
                          <td><%= req.name %></td>
                          <td><%= new Date(req.requested_at).toLocaleDateString('id-ID') %></td>
                          <td>
                            <span style="background:#fff3cd; color:#856404; padding:4px 8px; border-radius:4px; font-size:0.85rem; font-weight:bold;">
                              <%= req.status %>
                            </span>
                          </td>
                          <td style="display: flex; gap: 5px;">
                            <form action="/wd1/request/<%= req.id %>/approve" method="POST" onsubmit="return confirm('Terbitkan SK secara final?');">
                              <button type="submit" style="background:#28a745; border:none; padding:5px 10px; color:white; border-radius:4px; cursor:pointer; font-weight:bold;">Tanda Tangani SK</button>
                            </form>
                            <form action="/wd1/request/<%= req.id %>/reject" method="POST" onsubmit="return confirm('Tolak dokumen ini?');">
                              <button type="submit" style="background:#dc3545; border:none; padding:5px 10px; color:white; border-radius:4px; cursor:pointer; font-weight:bold;">Tolak</button>
                            </form>
                          </td>
                        </tr>
                      <% }) %>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </section>
          </div>

        </div>
      </main>
    </div>

    <div id="toaster" class="toaster"></div>
    <script src="/assets/js/basecoat.js"></script>
  </body>
</html>