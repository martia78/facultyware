<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Masuk — Sistem Pengajuan Pengunduran Diri Mahasiswa</title>
    <link rel="icon" href="/assets/favicon.svg" />
    <link rel="stylesheet" href="/assets/basecoat.min.css" />
    <link rel="stylesheet" href="/assets/theme-unand.css" />
  </head>
  <body>
    <div class="login-page">
      <div class="login-card">

        <div class="login-card-logo">
          <img src="/assets/images/logo-unand.png" alt="Logo Universitas Andalas" width="62" height="76" />
        </div>

        <h1 class="login-card-title">
          Sistem Pengajuan<br />
          Pengunduran Diri Mahasiswa
        </h1>
        <p class="login-card-university">Universitas Andalas</p>

        <div class="login-card-divider"></div>

        <form action="/login" method="POST" class="login-form" novalidate>

          <% if (error) { %>
          <div class="form-alert" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span><%= error %></span>
          </div>
          <% } %>

          <div class="login-field">
            <label class="login-field-label" for="username">Username</label>
            <div class="login-input-wrap">
              <input
                class="login-input"
                type="text"
                name="username"
                id="username"
                placeholder="Masukkan username"
                required
                autocomplete="username"
                autofocus
              />
            </div>
          </div>

          <div class="login-field">
            <label class="login-field-label" for="password">Password</label>
            <div class="login-input-wrap">
              <input
                class="login-input login-input--password"
                type="password"
                name="password"
                id="password"
                placeholder="Masukkan password"
                required
                autocomplete="current-password"
              />
              <button type="button" class="login-input-toggle" id="togglePassword" aria-label="Tampilkan password" aria-pressed="false">
                <svg class="login-eye-icon login-eye-icon--show" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                <svg class="login-eye-icon login-eye-icon--hide" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M17.94 17.94A10.94 10.94 0 0 1 12 20c-7 0-11-8-11-8a21.62 21.62 0 0 1 5.06-6.06M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a21.6 21.6 0 0 1-3.22 4.66M14.12 14.12a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
              </button>
            </div>
          </div>

          <button type="submit" class="login-submit-btn">MASUK</button>
        </form>

        <div class="login-card-divider"></div>

        <p class="login-card-roles-label">Login sebagai</p>
        <div class="login-card-roles">
          <div class="login-role-mini">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span class="login-role-mini-label">Mahasiswa</span>
          </div>
          <div class="login-role-mini">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            <span class="login-role-mini-label">Kaprodi</span>
          </div>
          <div class="login-role-mini">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            <span class="login-role-mini-label">Wakil Dekan 1</span>
          </div>
          <div class="login-role-mini">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span class="login-role-mini-label">Admin</span>
          </div>
        </div>

      </div>

      <p class="login-card-footer">&copy; <%= new Date().getFullYear() %> Universitas Andalas</p>
    </div>

    <script>
      (() => {
        const toggleBtn = document.getElementById('togglePassword');
        const passwordInput = document.getElementById('password');
        if (!toggleBtn || !passwordInput) return;

        const showIcon = toggleBtn.querySelector('.login-eye-icon--show');
        const hideIcon = toggleBtn.querySelector('.login-eye-icon--hide');

        toggleBtn.addEventListener('click', () => {
          const isPassword = passwordInput.type === 'password';
          passwordInput.type = isPassword ? 'text' : 'password';
          toggleBtn.setAttribute('aria-pressed', String(isPassword));
          toggleBtn.setAttribute('aria-label', isPassword ? 'Sembunyikan password' : 'Tampilkan password');
          showIcon.style.display = isPassword ? 'none' : '';
          hideIcon.style.display = isPassword ? '' : 'none';
        });
      })();
    </script>
  </body>
</html>
