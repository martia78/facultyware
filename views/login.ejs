<!doctype html>
<html lang="id">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Masuk — Sistem Pengajuan Pengunduran Diri Mahasiswa</title>
    <link rel="icon" href="/assets/favicon.svg" />
    <link rel="stylesheet" href="/assets/basecoat.min.css" />
    <link rel="stylesheet" href="/assets/theme-unand.css" />
  </head>
  <body>
    <div class="login-shell">
      <div class="login-card-wrap">

        <div class="login-card">
          <div class="unand-accent-bar"></div>

          <div class="login-card-grid">

            <form class="login-form-panel" action="/login" method="POST">
              <div class="form form-stack">

                <div class="form-row" style="gap: 0.75rem; margin-bottom: 0.25rem;">
                  <div class="unand-brand">
                    <div class="unand-brand-mark">
                      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                    </div>
                    <div class="unand-brand-text">
                      <span class="unand-brand-title">Universitas Andalas</span>
                      <span class="unand-brand-subtitle">Sistem Akademik Terpadu</span>
                    </div>
                  </div>
                  <div>
                    <h1 class="card-title" style="font-size: 1.25rem;">Pengajuan Pengunduran Diri</h1>
                    <p class="text-muted-foreground" style="font-size: 0.875rem; margin-top: 0.25rem;">Masuk dengan akun SIA Anda untuk melanjutkan.</p>
                  </div>
                </div>

                <% if (error) { %>
                <div class="form-alert" role="alert">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  <span><%= error %></span>
                </div>
                <% } %>

                <div class="field">
                  <label class="label" for="username">Username</label>
                  <input class="input" type="text" name="username" id="username"
                    placeholder="Masukkan username" required autocomplete="username" autofocus />
                </div>

                <div class="field">
                  <label class="label" for="password">Password</label>
                  <input class="input" type="password" name="password" id="password"
                    placeholder="Masukkan password" required autocomplete="current-password" />
                </div>

                <button class="btn-primary" type="submit" style="width: 100%;">
                  Masuk
                </button>

                <p class="text-muted-foreground text-center" style="font-size: 0.75rem;">
                  Lupa password? Hubungi Admin Akademik fakultas Anda.
                </p>
              </div>
            </form>

            <div class="login-card-panel--hide-mobile login-side-panel">
              <div class="login-side-content">
                <p style="font-size: 0.75rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.8;">Layanan Akademik</p>
                <h2 style="font-size: 1.5rem; font-weight: 700; margin-top: 0.5rem; line-height: 1.35;">Pengajuan permohonan pengunduran diri, tercatat dan terverifikasi resmi.</h2>
              </div>

              <ul class="login-feature-list">
                <li class="login-feature-item">
                  <div class="login-feature-bullet">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  </div>
                  <span style="font-size: 0.875rem; opacity: 0.9; padding-top: 0.125rem;">Diverifikasi Admin Akademik sebelum diteruskan</span>
                </li>
                <li class="login-feature-item">
                  <div class="login-feature-bullet">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  </div>
                  <span style="font-size: 0.875rem; opacity: 0.9; padding-top: 0.125rem;">Disetujui berjenjang oleh Kaprodi dan wd1</span>
                </li>
                <li class="login-feature-item">
                  <div class="login-feature-bullet">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  </div>
                  <span style="font-size: 0.875rem; opacity: 0.9; padding-top: 0.125rem;">Surat keputusan resmi dapat diunduh sebagai PDF</span>
                </li>
              </ul>
            </div>

          </div>
        </div>

        <p class="login-footer-note">
          &copy; <%= new Date().getFullYear() %> Universitas Andalas &mdash; Sistem Pengajuan Pengunduran Diri Mahasiswa.
        </p>
      </div>
    </div>

    <div id="toaster" class="toaster"></div>
    <script src="/assets/js/basecoat.js"></script>
  </body>
</html>
