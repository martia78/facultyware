<!doctype html>
<html lang="id">
  <head>
    <%- include('../partials/head', { title: pageTitle }) %>
  </head>
  <body class="page-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
      <%- include('../partials/topbar') %>

      <main class="app-content">
        <div class="content-narrow">

          <div class="dash-welcome">
            <h2 class="dash-welcome-title">Selamat datang, <%= user ? user.name : 'Mahasiswa' %>! 👋</h2>
            <p class="dash-welcome-sub">Kelola pengajuan pengunduran diri Anda dengan mudah.</p>
          </div>

          <%# Flash %>
          <% if (flash) { %>
          <div class="alert alert--<%= flash.type === 'success' ? 'success' : 'danger' %> mb-5">
            <%= flash.message %>
          </div>
          <% } %>

          <%# ── Informasi Mahasiswa (Nama / NIM / Program Studi) ───────────── %>
          <section class="student-info-bar">
            <div class="student-info-item">
              <span class="student-info-label">Nama Mahasiswa</span>
              <span class="student-info-value"><%= student ? student.name : (user ? user.name : '—') %></span>
            </div>
            <div class="student-info-divider"></div>
            <div class="student-info-item">
              <span class="student-info-label">NIM</span>
              <span class="student-info-value"><%= student ? student.regno : '—' %></span>
            </div>
            <div class="student-info-divider"></div>
            <div class="student-info-item">
              <span class="student-info-label">Program Studi</span>
              <span class="student-info-value"><%= student && student.department_name ? student.department_name : '—' %></span>
            </div>
          </section>

          <section class="stat-grid stat-grid--2">
            <div class="dash-stat-card <%= latest && latest.status === STATUS.DISETUJUI_FINAL ? 'dash-stat-card--green' : (latest && (latest.status === 3 || latest.status === 5) ? 'dash-stat-card--red' : 'dash-stat-card--green') %>">
              <div>
                <p class="dash-stat-label">Status Pengajuan</p>
                <p class="dash-stat-value <%= latest && latest.status === STATUS.DISETUJUI_FINAL ? 'dash-stat-value--green' : (latest && (latest.status === 3 || latest.status === 5) ? 'dash-stat-value--red' : 'dash-stat-value--green') %>">
                  <%= latest ? (STATUS_HEADLINE[latest.status] || '—') : 'Belum Ada' %>
                </p>
                <% if (latest) { %>
                <span class="badge <%= STATUS_BADGE[latest.status] || 'badge--gray' %>"><%= STATUS_LABEL[latest.status] || '—' %></span>
                <% } %>
                <% if (latest && latest.status === STATUS.DISETUJUI_FINAL) { %>
                <div style="margin-top:0.75rem;">
                  <a href="/mahasiswa/submissions/<%= latest.id %>/pdf"
                     class="btn-primary"
                     style="display:inline-flex;align-items:center;gap:6px;font-size:0.8125rem;padding:6px 14px;text-decoration:none;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Unduh SK (PDF)
                  </a>
                </div>
                <% } %>
                <% if (latest && (latest.status === 3 || latest.status === 5)) { %>
                <div style="margin-top:0.75rem;">
                  <a href="/mahasiswa/submissions/create"
                     class="btn-primary"
                     style="display:inline-flex;align-items:center;gap:6px;font-size:0.8125rem;padding:6px 14px;text-decoration:none;background:#6c757d;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v16m8-8H4"/></svg>
                    Ajukan Ulang
                  </a>
                </div>
                <% } %>
              </div>
              <div class="dash-stat-icon-wrap dash-stat-icon-wrap--green">
                <% if (latest && latest.status === STATUS.DISETUJUI_FINAL) { %>
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                <% } else { %>
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12l2 2 4-4"/></svg>
                <% } %>
              </div>
            </div>

            <div class="dash-stat-card dash-stat-card--blue">
              <div>
                <p class="dash-stat-label">Total Pengajuan</p>
                <p class="dash-stat-value dash-stat-value--blue"><%= totalSubmissions %></p>
                <p class="dash-stat-desc">Total semua pengajuan Anda</p>
              </div>
              <div class="dash-stat-icon-wrap dash-stat-icon-wrap--blue">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              </div>
            </div>
          </section>

          <%# Kartu bawah — kondisi berdasarkan status latest %>
          <% if (!latest) { %>
          <%# Belum pernah mengajukan — tampilkan CTA buat pengajuan %>
          <div class="dash-card">
            <div class="dash-card-body" style="padding-top:1.25rem;">
              <div class="empty-state">
                <div class="empty-state-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v16m8-8H4"/></svg>
                </div>
                <h3 class="empty-state-title">Belum Ada Pengajuan Aktif</h3>
                <p class="empty-state-desc">
                  Jika Anda berniat mengundurkan diri, siapkan Surat Permohonan dalam format PDF (maks. 5 MB) sebelum mengajukan.
                </p>
                <a href="/mahasiswa/submissions/create" class="btn-primary mt-4">Buat Pengajuan</a>
              </div>
            </div>
          </div>

          <% } else if (latest.status === STATUS.DISETUJUI_FINAL) { %>
          <%# Disetujui Final — tampilkan info SK, sembunyikan tombol buat pengajuan baru %>
          <div class="dash-card" style="border-left: 4px solid #28a745;">
            <div class="dash-card-body" style="padding-top:1.25rem;">
              <div style="display:flex;flex-direction:column;gap:0.75rem;">
                <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center;justify-content:space-between;">
                  <div>
                    <p style="margin:0;font-size:0.8125rem;color:var(--muted-foreground);">Nomor SK</p>
                    <code style="font-size:0.9rem;font-weight:600;"><%= latest.request_number %></code>
                  </div>
                  <div>
                    <p style="margin:0;font-size:0.8125rem;color:var(--muted-foreground);">Status</p>
                    <span class="badge badge--green">Disetujui Final</span>
                  </div>
                  <div>
                    <p style="margin:0;font-size:0.8125rem;color:var(--muted-foreground);">Tanggal Disetujui</p>
                    <p style="margin:0;font-size:0.875rem;"><%= latest.updated_at ? new Date(latest.updated_at).toLocaleDateString('id-ID',{day:'2-digit',month:'long',year:'numeric'}) : '—' %></p>
                  </div>
                  <div style="display:flex;gap:8px;flex-wrap:wrap;">
                    <a href="/mahasiswa/submissions/<%= latest.id %>/pdf"
                       class="btn-primary"
                       style="display:inline-flex;align-items:center;gap:6px;font-size:0.875rem;text-decoration:none;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                      Unduh SK (PDF)
                    </a>
                    <a href="/mahasiswa/submissions/<%= latest.id %>" class="btn-outline" style="font-size:0.875rem;text-decoration:none;">Lihat Detail</a>
                  </div>
                </div>
                <p style="margin:0;font-size:0.8rem;color:#28a745;">
                  ✓ Pengajuan pengunduran diri Anda telah disetujui secara resmi. SK dapat diunduh dan digunakan sebagai dokumen resmi.
                </p>
              </div>
            </div>
          </div>

          <% } else if (latest.status === 3 || latest.status === 5) { %>
          <%# Ditolak — tampilkan info penolakan + tombol ajukan ulang %>
          <div class="dash-card" style="border-left: 4px solid #dc3545;">
            <div class="dash-card-body" style="padding-top:1.25rem;">
              <div style="display:flex;flex-direction:column;gap:0.75rem;">
                <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center;justify-content:space-between;">
                  <div>
                    <p style="margin:0;font-size:0.8125rem;color:var(--muted-foreground);">Nomor Pengajuan</p>
                    <code style="font-size:0.9rem;font-weight:600;"><%= latest.request_number %></code>
                  </div>
                  <div>
                    <p style="margin:0;font-size:0.8125rem;color:var(--muted-foreground);">Status</p>
                    <span class="badge badge--red">Ditolak</span>
                  </div>
                  <div style="display:flex;gap:8px;">
                    <a href="/mahasiswa/submissions/create"
                       class="btn-primary"
                       style="display:inline-flex;align-items:center;gap:6px;font-size:0.875rem;text-decoration:none;">
                      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v16m8-8H4"/></svg>
                      Ajukan Ulang
                    </a>
                    <a href="/mahasiswa/submissions/<%= latest.id %>" class="btn-outline" style="font-size:0.875rem;text-decoration:none;">Lihat Alasan</a>
                  </div>
                </div>
                <p style="margin:0;font-size:0.8rem;color:#dc3545;">
                  Pengajuan Anda ditolak. Periksa alasan penolakan pada detail pengajuan, perbaiki dokumen, lalu ajukan kembali.
                </p>
              </div>
            </div>
          </div>

          <% } else { %>
          <%# Aktif (Draft / Menunggu / Diproses) — tampilkan info pengajuan, tanpa tombol buat baru %>
          <div class="dash-card">
            <div class="dash-card-body" style="padding-top:1.25rem;">
              <div style="display:flex;flex-direction:column;gap:0.75rem;">
                <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center;justify-content:space-between;">
                  <div>
                    <p style="margin:0;font-size:0.8125rem;color:var(--muted-foreground);">Nomor Pengajuan</p>
                    <code style="font-size:0.9rem;font-weight:600;"><%= latest.request_number %></code>
                  </div>
                  <div>
                    <p style="margin:0;font-size:0.8125rem;color:var(--muted-foreground);">Status Pengajuan</p>
                    <span class="badge <%= STATUS_BADGE[latest.status] || 'badge--gray' %>"><%= STATUS_LABEL[latest.status] || '—' %></span>
                  </div>
                  <div>
                    <p style="margin:0;font-size:0.8125rem;color:var(--muted-foreground);">Tanggal Pengajuan</p>
                    <p style="margin:0;font-size:0.875rem;"><%= latest.requested_at ? new Date(latest.requested_at).toLocaleDateString('id-ID',{day:'2-digit',month:'long',year:'numeric'}) : '—' %></p>
                  </div>
                  <a href="/mahasiswa/submissions/<%= latest.id %>" class="btn-primary" style="white-space:nowrap;">Lihat Detail</a>
                </div>
              </div>
            </div>
          </div>
          <% } %>

          <div class="dash-grid-main">

            <div class="dash-card">
              <div class="dash-card-header">
                <div class="dash-card-title-group">
                  <div class="dash-card-title-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  </div>
                  <h2 class="dash-card-title">Riwayat Pengajuan Terbaru</h2>
                </div>
                <a href="/mahasiswa/submissions" class="dash-card-action">
                  Lihat Semua
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
              </div>

              <div class="dash-card-body">
                <div class="table-wrap">
                  <table class="table">
                    <thead>
                      <tr>
                        <th>No Pengajuan</th>
                        <th>Tanggal Pengajuan</th>
                        <th>Status</th>
                        <th>Tahap Saat Ini</th>
                        <th></th>
                      </tr>
                    </thead>
                    <tbody>
                      <% if (recent3.length === 0) { %>
                      <tr>
                        <td colspan="5" class="text-center text-muted-foreground" style="padding:2rem 0;">
                          Belum ada riwayat pengajuan.
                        </td>
                      </tr>
                      <% } else { %>
                      <% recent3.forEach(sub => { %>
                      <tr>
                        <td><code style="font-size:0.8125rem;"><%= sub.request_number %></code></td>
                        <td>
                          <%= sub.requested_at ? new Date(sub.requested_at).toLocaleDateString('id-ID',{day:'2-digit',month:'long',year:'numeric'}) : '—' %>
                        </td>
                        <td>
                          <span class="badge <%= STATUS_BADGE[sub.status] || 'badge--gray' %>">
                            <%= STATUS_HEADLINE[sub.status] || sub.status %>
                          </span>
                        </td>
                        <td class="dash-col-stage"><%= CURRENT_STAGE[sub.status] || '—' %></td>
                        <td style="text-align:right;">
                          <a href="/mahasiswa/submissions/<%= sub.id %>" class="dash-table-detail-btn">
                            Detail
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                          </a>
                        </td>
                      </tr>
                      <% }) %>
                      <% } %>
                    </tbody>
                  </table>
                </div>
              </div>

              <div class="dash-card-footer-note">
                Menampilkan <%= recent3.length %> - <%= recent3.length %> dari <%= totalSubmissions %> data
              </div>
            </div>

            <div class="dash-card" id="tracking">
              <div class="dash-card-header">
                <div class="dash-card-title-group">
                  <div class="dash-card-title-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M20 4 8.12 15.88M14.47 14.48 20 20M8.12 8.12 12 12"/></svg>
                  </div>
                  <h2 class="dash-card-title">Tracking Status Pengajuan</h2>
                </div>
              </div>

              <div class="dash-card-body">
                <%- include('../partials/tracking', { timeline }) %>
              </div>
            </div>

          </div>

        </div>
      </main>
    </div>

    <div id="toaster" class="toaster"></div>
    <script src="/assets/js/basecoat.js"></script>
  </body>
</html>