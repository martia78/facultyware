<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8"><title>Detail Berkas #<%= request.id %></title>
    <link rel="stylesheet" href="https://unpkg.com/@basecoat/basecoat/dist/basecoat.min.css">
    <style>body{padding:2rem; max-width:700px; margin:0 auto;}</style>
</head>
<body>
    <div class="container">
        <h2>📄 Fitur 2: Detail Berkas Permohonan</h2>
        <hr>
        <h3><%= request.title %></h3>
        <p><b>Nama Pemohon:</b> <%= request.student_name %> | <b>NIM:</b> <%= request.student_nim %></p>
        <p><b>Email:</b> <%= request.student_email %></p>
        <div style="background:#eee; padding:1rem; border-radius:4px;"><%= request.description %></div>
        <br>
        
        <div style="background:#e6f4ea; padding:1rem; border:1px solid #006837; border-radius:4px;">
            📁 <b>Dokumen Pendukung Lampiran:</b> 
            <a href="#" onclick="alert('File download simulated: <%= request.supporting_document %>')" style="font-weight:bold; color:#006837;">Unduh Berkas Lampiran.pdf</a>
        </div>
        <br>

        <h3>Fitur 3: Evaluasi & Catatan Kaprodi</h3>
        <form action="/b16/request/<%= request.id %>/kaprodi-review" method="POST">
            <textarea name="notes" placeholder="Tulis alasan rekomendasi prodi atau penolakan..." class="form-control" rows="3" required></textarea>
            <br>
            <button type="submit" name="action" value="Setuju" class="btn btn-primary" style="background:#006837;">Rekomendasikan ke Fakultas (Kirim Email)</button>
            <button type="submit" name="action" value="Tolak" class="btn btn-default" style="color:red; border-color:red;">Tolak Berkas</button>
        </form>
    </div>
</body>
</html>