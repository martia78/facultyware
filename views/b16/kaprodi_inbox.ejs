<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8"><title>Kaprodi - Antrean Berkas Masuk</title>
    <link rel="stylesheet" href="https://unpkg.com/@basecoat/basecoat/dist/basecoat.min.css">
    <style>body{padding:2rem; background:#f4f6f9;} .card{background:white; padding:1.5rem; margin-bottom:1rem; border-radius:6px; border-left:5px solid #006837;}</style>
</head>
<body>
    <div class="container">
        <h2 style="color:#006837;">👨‍💼 Fitur 1: Antrean Pengajuan Berkas (Kaprodi View)</h2>
        <form action="/b16/kaprodi" method="GET" style="display:flex; gap:10px; margin-bottom:2rem;">
            <input type="text" name="search" placeholder="Cari nama/NIM pemohon..." value="<%= search %>" class="form-control">
            <button type="submit" class="btn style="background:#006837; color:white;">Cari Berkas</button>
        </form>
        
        <% if(requests.length === 0) { %><p>Tidak ada berkas masuk.</p><% } else { %>
            <% requests.forEach(r => { %>
                <div class="card">
                    <h4><%= r.title %></h4>
                    <p>Pemohon: <b><%= r.student_name %></b> (<%= r.student_nim %>)</p>
                    <a href="/b16/request/<%= r.id %>" class="btn btn-sm btn-primary">Buka & Periksa Berkas (Fitur 2)</a>
                </div>
            <% }) %>
        <% } %>
    </div>
</body>
</html>