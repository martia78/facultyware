<!doctype html>
<html lang="id">
  <head>
    <%- include('../partials/head', { title: pageTitle }) %>
  </head>
  <body class="page-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
      <%- include('../partials/topbar') %>

      <main class="app-content">
        <div class="content-narrow">

          <section class="stat-grid stat-grid--2 stat-grid--4">
            <div class="stat-card">
              <div class="stat-card-row">
                <div>
                  <div class="stat-card-label">Menunggu Verifikasi</div>
                  <div class="stat-card-value">0</div>
                </div>
                <div class="stat-card-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
              </div>
            </div>

            <div class="stat-card">
              <div class="stat-card-row">
                <div>
                  <div class="stat-card-label">Perlu Revisi</div>
                  <div class="stat-card-value">0</div>
                </div>
                <div class="stat-card-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                </div>
              </div>
            </div>

            <div class="stat-card">
              <div class="stat-card-row">
                <div>
                  <div class="stat-card-label">Diteruskan ke Prodi</div>
                  <div class="stat-card-value">0</div>
                </div>
                <div class="stat-card-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              </div>
            </div>

            <div class="stat-card">
              <div class="stat-card-row">
                <div>
                  <div class="stat-card-label">Total Mahasiswa</div>
                  <div class="stat-card-value">0</div>
                </div>
                <div class="stat-card-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                </div>
              </div>
            </div>
          </section>

          <div class="card">
            <header style="display:flex; align-items:center; justify-content:space-between;">
              <div>
                <h2>Pengajuan Menunggu Verifikasi</h2>
                <p>Pengajuan yang dikirim mahasiswa dan menunggu pemeriksaan kelengkapan dokumen.</p>
              </div>
              <a href="/admin/submissions" class="btn-sm-outline">Lihat Semua</a>
            </header>
            <section>
              <div class="table-wrap">
                <table class="table">
                  <thead>
                    <tr>
                      <th>NIM</th>
                      <th>Nama Mahasiswa</th>
                      <th>Tanggal Pengajuan</th>
                      <th>Status</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td colspan="5" class="text-center text-muted-foreground" style="padding: 2rem 0;">
                        Belum ada pengajuan yang menunggu verifikasi.
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </section>
          </div>

          <div class="card" style="margin-top: 1.5rem; border-left: 4px solid #dc3545;">
            <header>
              <h2 style="color: #dc3545; margin-bottom: 0.2rem;">🛑 Portal Terpadu Sistem Fakultas</h2>
              <p>Akses cepat ke berbagai modul pengajuan, verifikasi, dan penerbitan SK.</p>
            </header>
            <section style="display: flex; gap: 10px; flex-wrap: wrap; padding-top: 1rem;">
              <a href="/mahasiswa" style="background: #dc3545; color: white; padding: 0.6rem 1.2rem; border-radius: 4px; text-decoration: none; font-weight: bold;">Portal Mahasiswa</a>
              <a href="/dekan" style="background: #a71d2a; color: white; padding: 0.6rem 1.2rem; border-radius: 4px; text-decoration: none; font-weight: bold;">Portal Dekan</a>
              <a href="/b16/kaprodi" style="background: #006837; color: white; padding: 0.6rem 1.2rem; border-radius: 4px; text-decoration: none; font-weight: bold;">B16: Panel Kaprodi</a>
              <a href="/b16/wd1" style="background: #d39e00; color: white; padding: 0.6rem 1.2rem; border-radius: 4px; text-decoration: none; font-weight: bold;">B16: Panel WD1</a>
              <a href="/b16/radar" style="background: #333; color: white; padding: 0.6rem 1.2rem; border-radius: 4px; text-decoration: none; font-weight: bold;">B16: Radar Global</a>
            </section>
          </div>

        </div>
      </main>
    </div>

    <div id="toaster" class="toaster"></div>
    <script src="/assets/js/basecoat.js"></script>
  </body>
</html>