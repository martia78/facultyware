<!doctype html>
<html lang="id">
  <head>
    <%- include('../partials/head', { title: pageTitle }) %>
  </head>
  <body class="page-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
      <%- include('../partials/topbar') %>

      <main class="app-content">
        <div class="content-narrow">

          <section class="stat-grid stat-grid--2 stat-grid--4">
            <div class="stat-card">
              <div class="stat-card-row">
                <div>
                  <div class="stat-card-label">Menunggu Verifikasi</div>
                  <div class="stat-card-value"><%= requests.filter(r => r.status === 'Pending').length %></div>
                </div>
                <div class="stat-card-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
              </div>
            </div>

            <div class="stat-card">
              <div class="stat-card-row">
                <div>
                  <div class="stat-card-label">Perlu Revisi</div>
                  <div class="stat-card-value"><%= requests.filter(r => r.status === 'Revision').length %></div>
                </div>
                <div class="stat-card-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                </div>
              </div>
            </div>

            <div class="stat-card">
              <div class="stat-card-row">
                <div>
                  <div class="stat-card-label">Diteruskan ke Prodi</div>
                  <div class="stat-card-value"><%= requests.filter(r => r.status === 'Approved_Admin').length %></div>
                </div>
                <div class="stat-card-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              </div>
            </div>

            <div class="stat-card">
              <div class="stat-card-row">
                <div>
                  <div class="stat-card-label">Total Pengajuan</div>
                  <div class="stat-card-value"><%= requests.length %></div>
                </div>
                <div class="stat-card-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                </div>
              </div>
            </div>
          </section>

          <div class="card">
            <header style="display:flex; align-items:center; justify-content:space-between; flex-wrap: wrap; gap: 10px;">
              <div>
                <h2>Pengajuan Aktif (Radar Lacak)</h2>
                <p>Pengajuan yang dikirim mahasiswa dan menunggu pemeriksaan kelengkapan dokumen.</p>
              </div>
              <form method="GET" action="/admin" style="display: flex; gap: 5px;">
                <input type="text" name="search" placeholder="Cari NIM atau Nama..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" style="padding: 6px 10px; border: 1px solid #ccc; border-radius: 4px;">
                <button type="submit" style="background: #333; color: white; border: none; padding: 6px 15px; border-radius: 4px; cursor: pointer;">Cari</button>
              </form>
            </header>
            <section>
              <div class="table-wrap">
                <table class="table">
                  <thead>
                    <tr>
                      <th>NIM</th>
                      <th>Nama Mahasiswa</th>
                      <th>Tanggal Pengajuan</th>
                      <th>Status</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (requests.length === 0) { %>
                      <tr>
                        <td colspan="5" class="text-center text-muted-foreground" style="padding: 2rem 0;">
                          Belum ada pengajuan aktif di dalam sistem.
                        </td>
                      </tr>
                    <% } else { %>
                      <% requests.forEach(req => { %>
                        <tr>
                          <td><strong><%= req.regno %></strong></td>
                          <td><%= req.name %></td>
                          <td><%= new Date(req.requested_at).toLocaleDateString('id-ID') %></td>
                          <td>
                            <span style="background:#e9ecef; color:#495057; padding:4px 8px; border-radius:4px; font-size:0.85rem; font-weight:bold;">
                              <%= req.status %>
                            </span>
                          </td>
                          <td>
                            <a href="/admin/request/<%= req.id %>" style="color: #0056b3; font-weight: bold; text-decoration: none;">Cek Detail &rarr;</a>
                          </td>
                        </tr>
                      <% }) %>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </section>
          </div>

        </div>
      </main>
    </div>

    <div id="toaster" class="toaster"></div>
    <script src="/assets/js/basecoat.js"></script>
  </body>
</html>