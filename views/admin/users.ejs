<!doctype html>
<html lang="id">
  <head>
    <%- include('../partials/head', { title: pageTitle }) %>
  </head>
  <body class="page-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
      <%- include('../partials/topbar') %>

      <main class="app-content">
        <div class="content-narrow">

          <div class="card" style="margin-bottom: 2rem; border-top: 4px solid #0056b3;">
            <header>
              <h2 style="color: #0056b3;">Tambah Pengguna Baru</h2>
            </header>
            <section>
              <form action="/admin/users/add" method="POST" style="display: flex; gap: 15px; flex-wrap: wrap; align-items: flex-end;">
                <div style="flex: 1; min-width: 200px;">
                  <label style="font-weight: bold; font-size: 0.85rem;">Username / NIM</label>
                  <input type="text" name="username" class="form-control" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
                </div>
                <div style="flex: 1; min-width: 200px;">
                  <label style="font-weight: bold; font-size: 0.85rem;">Nama Lengkap</label>
                  <input type="text" name="name" class="form-control" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
                </div>
                <div style="flex: 1; min-width: 200px;">
                  <label style="font-weight: bold; font-size: 0.85rem;">Password</label>
                  <input type="password" name="password" class="form-control" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
                </div>
                <div style="flex: 1; min-width: 150px;">
                  <label style="font-weight: bold; font-size: 0.85rem;">Role</label>
                  <select name="role_id" class="form-control" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
                    <option value="1">Admin</option>
                    <option value="2">Kaprodi</option>
                    <option value="3">Wakil Dekan 1</option>
                    <option value="4">Mahasiswa</option>
                  </select>
                </div>
                <div>
                  <button type="submit" style="background: #0056b3; color: white; padding: 9px 20px; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">+ Tambah</button>
                </div>
              </form>
            </section>
          </div>

          <div class="card">
            <header>
              <h2>Daftar Pengguna Sistem</h2>
            </header>
            <section>
              <div class="table-wrap">
                <table class="table">
                  <thead>
                    <tr>
                      <th>ID</th>
                      <th>Username / NIM</th>
                      <th>Nama</th>
                      <th>Role</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% users.forEach(u => { %>
                      <tr>
                        <td><%= u.id %></td>
                        <td><strong><%= u.username %></strong></td>
                        <td><%= u.name %></td>
                        <td><span style="background:#e9ecef; padding:4px 8px; border-radius:4px; font-size:0.85rem; font-weight:bold;"><%= u.role || 'No Role' %></span></td>
                        <td>
                          <% if (u.id !== 1) { %>
                            <form action="/admin/users/delete/<%= u.id %>" method="POST" onsubmit="return confirm('Yakin ingin menghapus pengguna ini?');">
                              <button type="submit" style="background: #dc3545; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;">Hapus</button>
                            </form>
                          <% } else { %>
                            <span style="color: #666; font-size: 0.85rem;">Master Admin</span>
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </section>
          </div>

        </div>
      </main>
    </div>
    <script src="/assets/js/basecoat.js"></script>
  </body>
</html>