<header class="app-topbar">
  <%# Tombol toggle sidebar — berfungsi di mobile DAN desktop %>
  <button type="button" class="sidebar-toggle-btn" id="sidebar-toggle-btn" aria-label="Toggle navigasi">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
  </button>

  <div style="flex: 1; min-width: 0;">
    <h1 class="app-topbar-title"><%= pageTitle %></h1>
    <% if (typeof pageSubtitle !== 'undefined' && pageSubtitle) { %>
    <p class="app-topbar-subtitle"><%= pageSubtitle %></p>
    <% } %>
  </div>

  <% if (typeof user !== 'undefined' && user) { %>
  <a href="<%= user.role === 'mahasiswa' ? '/mahasiswa/profile' : '#' %>" class="app-topbar-user">
    <span class="app-topbar-avatar"><%= user.name ? user.name.charAt(0).toUpperCase() : '?' %></span>
    <span class="app-topbar-user-text">
      <span class="app-topbar-user-name"><%= user.name %></span>
      <span class="app-topbar-user-sub"><%= user.username %></span>
    </span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="app-topbar-user-chevron"><polyline points="6 9 12 15 18 9"/></svg>
  </a>
  <% } %>
</header>

<div class="mobile-menu-overlay" id="mobile-menu-overlay"></div>

<script>
  (() => {
    const btn     = document.getElementById('sidebar-toggle-btn');
    const overlay = document.getElementById('mobile-menu-overlay');
    const sidebar = document.querySelector('.app-sidebar');
    const main    = document.querySelector('.app-main');
    if (!btn || !sidebar) return;

    const COLLAPSED_KEY = 'sidebar_collapsed';
    const isDesktop = () => window.innerWidth >= 1024;

    const collapsed = localStorage.getItem(COLLAPSED_KEY) === 'true';
    if (isDesktop() && collapsed) {
      sidebar.classList.add('app-sidebar--collapsed');
      main?.classList.add('app-main--sidebar-collapsed');
    }

    const closeMobile = () => {
      sidebar.classList.remove('app-sidebar--mobile-open');
      overlay?.classList.remove('mobile-menu-overlay--open');
    };

    btn.addEventListener('click', () => {
      if (isDesktop()) {
        
        const isCollapsed = sidebar.classList.toggle('app-sidebar--collapsed');
        main?.classList.toggle('app-main--sidebar-collapsed', isCollapsed);
        localStorage.setItem(COLLAPSED_KEY, isCollapsed);
      } else {
        
        const isOpen = sidebar.classList.toggle('app-sidebar--mobile-open');
        overlay?.classList.toggle('mobile-menu-overlay--open', isOpen);
      }
    });

    overlay?.addEventListener('click', closeMobile);
  })();
</script>
