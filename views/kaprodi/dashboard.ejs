<!doctype html>
<html lang="id">
<head>
    <%- include('../partials/head', { title: pageTitle }) %>
    <style>
        .badge { padding: 0.25rem 0.6rem; border-radius: 4px; font-weight: bold; font-size: 0.85rem; }
        .badge-kuning { background-color: #fff3cd; color: #856404; border: 1px solid #ffeeba; }
        .badge-hijau { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .badge-merah { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
        .btn-sm { padding: 0.3rem 0.6rem; font-size: 0.875rem; text-decoration: none; border-radius: 4px; }
    </style>
</head>
<body class="page-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main">
        <%- include('../partials/topbar') %>

        <main class="app-content">
            <div class="content-narrow">
                
                <h2 style="margin-bottom: 1.5rem;">Dashboard Ketua Program Studi</h2>

                <section class="stat-grid stat-grid--3" style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 2rem;">
                    <div class="card" style="border-top: 4px solid #ffc107; padding: 1.5rem; text-align: center;">
                        <h4 style="margin: 0; color: #666;">Menunggu Verifikasi</h4>
                        <h1 style="margin: 0.5rem 0 0 0; color: #333;"><%= stats.menunggu %></h1>
                    </div>
                    <div class="card" style="border-top: 4px solid #28a745; padding: 1.5rem; text-align: center;">
                        <h4 style="margin: 0; color: #666;">Disetujui Prodi</h4>
                        <h1 style="margin: 0.5rem 0 0 0; color: #333;"><%= stats.disetujui %></h1>
                    </div>
                    <div class="card" style="border-top: 4px solid #dc3545; padding: 1.5rem; text-align: center;">
                        <h4 style="margin: 0; color: #666;">Ditolak</h4>
                        <h1 style="margin: 0.5rem 0 0 0; color: #333;"><%= stats.ditolak %></h1>
                    </div>
                </section>

                <div class="card">
                    <header style="display:flex; align-items:center; justify-content:space-between; margin-bottom: 1rem;">
                        <div>
                            <h3 style="margin: 0;">Daftar Pengajuan Pengunduran Diri</h3>
                            <p style="margin: 0; color: #666; font-size: 0.9rem;">Kelola antrean permohonan mahasiswa di tingkat program studi.</p>
                        </div>
                    </header>
                    
                    <div class="table-wrap">
                        <table class="table" style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr style="border-bottom: 2px solid #ddd; text-align: left;">
                                    <th style="padding: 1rem 0.5rem;">No Surat</th>
                                    <th>NIM</th>
                                    <th>Nama Mahasiswa</th>
                                    <th>Tanggal Pengajuan</th>
                                    <th>Status</th>
                                    <th style="text-align: center;">Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (requests && requests.length > 0) { %>
                                    <% requests.forEach(function(req) { %>
                                        <tr style="border-bottom: 1px solid #eee;">
                                            <td style="padding: 1rem 0.5rem;"><%= req.no_surat || '-' %></td>
                                            <td><%= req.nim %></td>
                                            <td><strong><%= req.student_name %></strong></td>
                                            <td>
                                                <%= new Date(req.tanggal_pengajuan).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                                            </td>
                                            <td>
                                                <% if (req.status === 'Pending' || req.status === 'Menunggu') { %>
                                                    <span class="badge badge-kuning">Menunggu</span>
                                                <% } else if (req.status === 'Approved' || req.status === 'Disetujui') { %>
                                                    <span class="badge badge-hijau">Disetujui</span>
                                                <% } else { %>
                                                    <span class="badge badge-merah">Ditolak</span>
                                                <% } %>
                                            </td>
                                            <td style="text-align: center;">
                                                <a href="/kaprodi/request/<%= req.request_id %>" class="btn-sm" style="background: #0056b3; color: white;">Tinjau Dokumen</a>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" style="text-align: center; padding: 3rem; color: #888;">
                                            Belum ada pengajuan pengunduran diri yang masuk ke prodi.
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <script src="/assets/js/basecoat.js"></script>
</body>
</html>